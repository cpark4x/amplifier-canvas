+
+    const listenerCounts = await isolatedApp.evaluate(({ BrowserWindow, ipcMain }, channels) => {
+      return new Promise<{
+        beforeInput: number
+        beforeResize: number
+        afterInput: number
+        afterResize: number
+      }>((resolve, reject) => {
+        const win = BrowserWindow.getAllWindows()[0]
+
+        if (!win) {
+          reject(new Error('No window available to close'))
+          return
+        }
+
+        const beforeInput = ipcMain.listenerCount(channels.input)
+        const beforeResize = ipcMain.listenerCount(channels.resize)
+
+        win.once('closed', () => {
+          resolve({
+            beforeInput,
+            beforeResize,
+            afterInput: ipcMain.listenerCount(channels.input),
+            afterResize: ipcMain.listenerCount(channels.resize),
+          })
+        })
+
+        win.close()
+      })
+    }, {
+      input: IPC_CHANNELS.TERMINAL_INPUT,
+      resize: IPC_CHANNELS.TERMINAL_RESIZE,
+    })
+
+    expect(listenerCounts.beforeInput).toBeGreaterThan(0)
+    expect(listenerCounts.beforeResize).toBeGreaterThan(0)
+    expect(listenerCounts.afterInput).toBe(0)
+    expect(listenerCounts.afterResize).toBe(0)
+  })
