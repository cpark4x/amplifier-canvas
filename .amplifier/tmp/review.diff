+/** Output markers searched for in the dev-server stream. */
+const MARKER_INSTALL_ERROR = 'Electron failed to install';
+const MARKER_DEV_STARTED   = 'starting electron';
+const MARKER_DEV_RUNNING   = 'dev server running';
+/** Maximum bytes retained in the rolling output buffer. */
+const MAX_OUTPUT_BYTES = 8 * 1024;
+
+/**
+ * Spawn electron-vite dev and resolve as soon as a success or failure pattern
+ * is detected in the output stream — no need to wait for the full timeout.
+ *
+ * @param {string} cwd
+ * @param {number} timeoutMs  Upper bound; process is killed on success/failure too.
+ * @returns {Promise<{ started?: boolean, installError?: boolean, timedOut?: boolean, exited?: boolean, error?: string, output: string }>}
+ */
+function probeDevServer(cwd, timeoutMs = 15_000) {
+  return new Promise((done) => {
+    const proc = spawn('npx', ['electron-vite', 'dev'], {
+      cwd,
+      stdio: ['pipe', 'pipe', 'pipe'],
+      detached: process.platform !== 'win32',
+    });
+
+    let output = '';
+    let settled = false;
+
+    function settle(result) {
+      if (settled) return;
+      settled = true;
+      clearTimeout(timer);
+      // On POSIX, kill the entire process group so child processes don't linger.
+      try {
+        if (process.platform !== 'win32' && proc.pid) {
+          process.kill(-proc.pid, 'SIGTERM');
+        } else {
+          proc.kill('SIGTERM');
+        }
+      } catch {
+        try { proc.kill('SIGTERM'); } catch { /* already exited */ }
+      }
+      done(result);
+    }
+
+    const timer = setTimeout(() => {
+      settle({ timedOut: true, output });
+    }, timeoutMs);
+
+    function onData(chunk) {
+      output += chunk.toString();
+      if (output.includes(MARKER_INSTALL_ERROR)) {
+        settle({ installError: true, output });
+      } else if (output.includes(MARKER_DEV_STARTED) || output.includes(MARKER_DEV_RUNNING)) {
+        settle({ started: true, output });
+      }
+      // Cap the rolling buffer so long-running probes don't accumulate unbounded memory.
+      if (output.length > MAX_OUTPUT_BYTES) {
+        output = output.slice(output.length - MAX_OUTPUT_BYTES);
+      }
+    }
+
+    proc.stdout.on('data', onData);
+    proc.stderr.on('data', onData);
+    proc.on('error', (err) => settle({ error: err.message, output }));
+    proc.on('close', () => { if (!settled) settle({ exited: true, output }); });
+  });
 }
 
